{
  "name": "@gentorial/ai",
  "version": "0.3.0",
  "description": "Provider-neutral prompt compilation and generation pipeline for Gentorial.",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --sourcemap --clean && tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --root ../.. --config vitest.config.ts packages/ai/src",
    "pack:check": "pnpm pack --dry-run"
  },
  "keywords": [
    "gentorial",
    "ai",
    "education"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@gentorial/core": "workspace:^"
  }
}
